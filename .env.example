# Databricks
DATABRICKS_PROFILE=DEFAULT
DATABRICKS_HOST=https://fe-vm-jdub-vm-serverless.cloud.databricks.com

# MAS endpoint (existing)
MAS_ENDPOINT_NAME=mas-cfcbc058-endpoint

# Genie spaces config (JSON array, see README)
GENIE_SPACES_JSON='[]'

# Lakebase Postgres
# NOTE: Instance "multi-genie-viz-app" could not be created (workspace quota full).
# The app currently uses the shared dev instance "jdub-lakebase-db-instance".
# To migrate to a dedicated instance, free quota, re-run scripts/provision-lakebase.sh,
# and update LAKEBASE_INSTANCE + LAKEBASE_HOST below.
LAKEBASE_INSTANCE=jdub-lakebase-db-instance
LAKEBASE_HOST=instance-5efe91d9-c581-41c5-9f8b-c21cdbcfe74f.database.cloud.databricks.com
LAKEBASE_DATABASE=multi_genie_app
LAKEBASE_USER=
LAKEBASE_PASSWORD=

# Optional: override the Genie monitoring feedback API path if it differs at your workspace
# GENIE_FEEDBACK_PATH=/api/2.0/genie/spaces/{space_id}/conversations/{conversation_id}/messages/{message_id}/feedback

# Server
PORT=8000
NODE_ENV=development
